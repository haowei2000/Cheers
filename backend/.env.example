# 数据库等见项目文档，此处仅列常用项示例

# 日志目录（相对 backend 目录）；留空则仅控制台。错误会写入 error.log
# LOG_DIR=data/logs
# LOG_MAX_BYTES=5242880
# LOG_BACKUP_COUNT=3

# 引导 Bot 使用本地 LLM（如 Ollama），不配置则用关键词匹配
# GUIDE_LLM_BASE_URL=http://localhost:11434/v1
# GUIDE_LLM_MODEL=qwen2.5:7b
# GUIDE_LLM_API_KEY=
# GUIDE_LLM_TEMPERATURE=0.7
# GUIDE_LLM_MAX_TOKENS=1000

# S3-compatible object storage (RustFS / S3 / MinIO / R2)
# STORAGE_BACKEND=s3
# STORAGE_S3_ENDPOINT=http://localhost:9000
# STORAGE_S3_PUBLIC_ENDPOINT=http://localhost:9000
# STORAGE_S3_REGION=us-east-1
# STORAGE_S3_ACCESS_KEY=change-me-access-key
# STORAGE_S3_SECRET_KEY=change-me-secret-key
# STORAGE_S3_BUCKET=agentnexus-files
# STORAGE_S3_FORCE_PATH_STYLE=true
# STORAGE_S3_AUTO_CREATE_BUCKET=true
# STORAGE_PRESIGN_EXPIRES_SECONDS=900
# FILE_UPLOAD_MAX_BYTES=26214400
# FILE_UPLOAD_ALLOWED_TYPES=application/pdf,application/vnd.openxmlformats-officedocument.wordprocessingml.document,text/plain
# BACKEND_PIP_INDEX_URL=https://pypi.org/simple
# LLM_LOCALHOST_ALIAS=host.docker.internal
