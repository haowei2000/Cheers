{
  admin off
  log {
    output stdout
    format console
  }
}

http://{$APP_DOMAIN} {
  redir https://{$APP_DOMAIN}{uri} 301
}

{$APP_DOMAIN} {
  tls {$TLS_CERT_FILE} {$TLS_KEY_FILE}
  encode gzip

  handle /api/v1/* {
    reverse_proxy backend:8000
  }

  handle /api/* {
    reverse_proxy backend:8000
  }

  handle /docs* {
    reverse_proxy backend:8000
  }

  handle /openapi* {
    reverse_proxy backend:8000
  }

  handle /health* {
    reverse_proxy backend:8000
  }

  handle /ws* {
    reverse_proxy backend:8000
  }

  handle /preview* {
    reverse_proxy kkfileview:8012
  }

  handle /{$STORAGE_S3_BUCKET}/* {
    reverse_proxy rustfs:9000
  }

  handle {
    reverse_proxy frontend:80
  }
}
