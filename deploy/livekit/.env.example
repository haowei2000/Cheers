# DNS for this name must point to the dedicated media server.
LIVEKIT_DOMAIN=voice.example.com

# Generate distinct production credentials. The API secret should be at least
# 32 random characters, for example: openssl rand -hex 32
LIVEKIT_API_KEY=replace-with-a-long-random-key
LIVEKIT_API_SECRET=replace-with-a-long-random-secret

# Public Cheers gateway endpoint. LiveKit signs every request with the API
# secret and the gateway verifies both JWT and raw-body SHA-256.
CHEERS_VOICE_WEBHOOK_URL=https://cheers.example.com/api/v1/voice/livekit/webhook

# Pin an image version after validation in staging. `latest` is convenient for
# initial evaluation but should not be used for unattended production upgrades.
LIVEKIT_IMAGE=livekit/livekit-server:latest
