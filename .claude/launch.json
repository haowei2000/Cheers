{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "frontend",
      "runtimeExecutable": "bash",
      "runtimeArgs": ["-c", "cd frontend && npm run dev"],
      "port": 5173,
      "autoPort": true
    },
    {
      "name": "frontend-cluster",
      "runtimeExecutable": "bash",
      "runtimeArgs": ["-c", "cd frontend && VITE_API_PROXY_TARGET=http://localhost:30080 VITE_WS_PROXY_TARGET=ws://localhost:30080 npm run dev"],
      "port": 5174,
      "autoPort": true
    },
    {
      "name": "gateway",
      "runtimeExecutable": "bash",
      "runtimeArgs": ["server/.dev/run-dev.sh"],
      "port": 8000
    }
  ]
}
