{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "frontend",
      "runtimeExecutable": "bash",
      "runtimeArgs": ["-c", "cd frontend && npm run dev -- --port 5174 --strictPort"],
      "port": 5174,
      "autoPort": false
    },
    {
      "name": "frontend-cluster",
      "runtimeExecutable": "bash",
      "runtimeArgs": ["-c", "cd frontend && VITE_API_PROXY_TARGET=http://localhost:30080 VITE_WS_PROXY_TARGET=ws://localhost:30080 npm run dev -- --port 5175 --strictPort"],
      "port": 5175,
      "autoPort": false
    },
    {
      "name": "gateway",
      "runtimeExecutable": "bash",
      "runtimeArgs": ["server/.dev/run-dev.sh"],
      "port": 8000
    }
  ]
}
