# AgentNexus 环境变量示例
# 复制为 .env 并填写实际值

# 数据库（主业务库 SQLite）
DATABASE_URL=sqlite+aiosqlite:///data/main.db

# Context Store 用 SQLite（四层记忆，独立文件）
SQLITE_CONTEXT_PATH=data/context_store/context.db

# Redis（Bot 响应队列等）
REDIS_URL=redis://localhost:6379/0

# 数据根目录（上传、转换、记忆 MD 等）
DATA_DIR=data

# 调试
DEBUG=false

# 系统 LLM（RECENT 压缩等，M2 可选；不配置则用简单截断）
# SYSTEM_LLM_API_KEY=
# SYSTEM_LLM_BASE_URL=https://api.openai.com/v1
# SYSTEM_LLM_MODEL=gpt-4o-mini

# S3-compatible object storage (RustFS / S3 / MinIO / R2)
# STORAGE_BACKEND=s3
# STORAGE_S3_ENDPOINT=http://rustfs:9000
# STORAGE_S3_PUBLIC_ENDPOINT=http://localhost:9000
# STORAGE_S3_REGION=us-east-1
# STORAGE_S3_ACCESS_KEY=change-me-access-key
# STORAGE_S3_SECRET_KEY=change-me-secret-key
# STORAGE_S3_BUCKET=agentnexus-files
# STORAGE_S3_FORCE_PATH_STYLE=true
# STORAGE_S3_AUTO_CREATE_BUCKET=true
# STORAGE_PRESIGN_EXPIRES_SECONDS=900
# FILE_UPLOAD_MAX_BYTES=26214400
# FILE_UPLOAD_ALLOWED_TYPES=application/pdf,application/vnd.openxmlformats-officedocument.wordprocessingml.document,text/plain
# BACKEND_PIP_INDEX_URL=https://pypi.org/simple
# LLM_LOCALHOST_ALIAS=host.docker.internal
#
# RustFS container settings (keep credentials aligned with STORAGE_S3_ACCESS_KEY / STORAGE_S3_SECRET_KEY)
# RUSTFS_ACCESS_KEY=change-me-access-key
# RUSTFS_SECRET_KEY=change-me-secret-key
