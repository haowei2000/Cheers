# AgentNexus 环境变量示例
# 复制为 .env 并填写实际值。不要把本示例中的 change-me 或本地开发密钥用于生产环境。

# Docker 宿主机端口（遇到端口冲突时可修改）
BACKEND_HOST_PORT=8000
FRONTEND_HOST_PORT=80
REDIS_HOST_PORT=6389
POSTGRES_HOST_PORT=5432
RUSTFS_API_HOST_PORT=9000
RUSTFS_CONSOLE_HOST_PORT=9001
KKFILEVIEW_HOST_BIND=127.0.0.1
KKFILEVIEW_HOST_PORT=8012

# PostgreSQL
POSTGRES_USER=agentnexus
POSTGRES_PASSWORD=change-me-postgres-password
POSTGRES_DB=agentnexus

# 数据库（主业务库 PostgreSQL）
DATABASE_URL=postgresql+asyncpg://agentnexus:change-me-postgres-password@localhost:5432/agentnexus

# 测试数据库（pytest 默认使用 5433；若真实 Docker Compose 端口不同，运行测试时显式覆盖）
TEST_DATABASE_URL=postgresql+asyncpg://agentnexus:change-me-postgres-password@localhost:5433/agentnexus_test

# Context Store（四层记忆，默认同主库）
CONTEXT_DB_URL=postgresql+asyncpg://agentnexus:change-me-postgres-password@localhost:5432/agentnexus

# 数据库迁移控制
# 默认随 backend 启动执行 upgrade head；回退时使用 db-migrate 工具服务显式 downgrade。
DB_MIGRATION_MODE=upgrade
DB_MIGRATION_TARGET=head
CONTEXT_DB_MIGRATION_MODE=upgrade
CONTEXT_DB_MIGRATION_TARGET=head
ALLOW_DB_DOWNGRADE=0

# Redis（Bot 响应队列等）
REDIS_URL=redis://localhost:6379/0
BOT_PIPELINE_REDIS_READ_COUNT=8
BOT_EVENT_REDIS_READ_COUNT=8

# 数据根目录（上传、转换、记忆 MD 等）
DATA_DIR=data

# 后端记忆分页（仅用于 Bot memory，不影响前端消息分页）
MEMORY_HISTORY_PAGE_MAX_CHARS=50000
MEMORY_HISTORY_SUMMARY_MAX_CHARS=1500

# 调试
DEBUG=false

STORAGE_BACKEND=s3
STORAGE_S3_ENDPOINT=http://rustfs:9000
STORAGE_S3_PUBLIC_ENDPOINT=http://localhost:9000
STORAGE_S3_REGION=us-east-1
STORAGE_S3_ACCESS_KEY=agentnexus-local-access-key
STORAGE_S3_SECRET_KEY=agentnexus-local-secret-key
STORAGE_S3_BUCKET=agentnexus-files
STORAGE_S3_FORCE_PATH_STYLE=true
STORAGE_S3_AUTO_CREATE_BUCKET=true
STORAGE_PRESIGN_EXPIRES_SECONDS=900
FILE_UPLOAD_MAX_BYTES=26214400
FILE_RETENTION_DAYS=365
FILE_RETENTION_CLEANUP_INTERVAL_SECONDS=86400
FILE_PENDING_UPLOAD_TTL_SECONDS=3600
FILE_UPLOAD_ALLOWED_TYPES=application/pdf,application/msword,application/vnd.openxmlformats-officedocument.wordprocessingml.document,application/vnd.ms-excel,application/vnd.openxmlformats-officedocument.spreadsheetml.sheet,application/vnd.ms-powerpoint,application/vnd.openxmlformats-officedocument.presentationml.presentation,application/ofd,application/rtf,text/csv,text/html,text/plain,text/markdown,application/zip,application/vnd.rar,application/x-7z-compressed,application/x-tar,application/gzip,application/epub+zip
PUBLIC_BASE_URL=http://localhost
KKFILEVIEW_ENABLED=true
KKFILEVIEW_BASE_URL=http://localhost/preview
KKFILEVIEW_TOKEN_TTL_SECONDS=600
KKFILEVIEW_IMAGE=keking/kkfileview:latest
KKFILEVIEW_TRUST_HOST=localhost
KKFILEVIEW_FILE_DIR=/opt/kkfileview/file/
KKFILEVIEW_OFFICE_PREVIEW_TYPE=pdf
KKFILEVIEW_PDF_DOWNLOAD_DISABLE=true
KKFILEVIEW_PDF_PRINT_DISABLE=true
KKFILEVIEW_MEDIA_CONVERT_DISABLE=true
AVATAR_UPLOAD_MAX_BYTES=2097152
AVATAR_UPLOAD_ALLOWED_TYPES=image/png,image/jpeg,image/webp,image/gif

RUSTFS_ACCESS_KEY=agentnexus-local-access-key
RUSTFS_SECRET_KEY=agentnexus-local-secret-key
JWT_SECRET_KEY=change-me-to-a-long-random-string

# ===== DingTalk Login（可选）=====
# 开启后必须同时配置 ClientID、ClientSecret 和允许登录的 CorpID 白名单。
# 钉钉开放平台回调 URL 示例：
#   ${PUBLIC_BASE_URL}/api/v1/auth/dingtalk/callback
# 需要委托权限：openid、corpid、Contact.User.Read；端内免登使用 Contact.User.Read。
DINGTALK_LOGIN_ENABLED=false
DINGTALK_CLIENT_ID=
DINGTALK_CLIENT_SECRET=
DINGTALK_ALLOWED_CORP_IDS=
DINGTALK_DEFAULT_CORP_ID=
DINGTALK_OAUTH_AUTHORIZE_URL=https://login.dingtalk.com/oauth2/auth
DINGTALK_OAUTH_TOKEN_URL=https://api.dingtalk.com/v1.0/oauth2/userAccessToken
DINGTALK_USER_INFO_URL=https://api.dingtalk.com/v1.0/contact/users/me

# ===== Initial administrator and seed locale (created on first SEED_DATA=1 startup) =====
# Production/public deployments must set a strong administrator password.
# Empty values and example defaults stop SEED_DATA=1 startup.
APP_DEFAULT_LOCALE=en
ADMIN_USERNAME=admin
ADMIN_PASSWORD=
ADMIN_DISPLAY_NAME=System Administrator

# ===== Helper Bot LLM（可选；留空则关键词匹配帮助文档）=====
HELPER_LLM_BASE_URL=
HELPER_LLM_MODEL=
HELPER_LLM_API_KEY=
HELPER_LLM_TEMPERATURE=0.7
HELPER_LLM_MAX_TOKENS=1000

# ===== Agent Bridge =====
# 管理/调试 HTTP 接口共享密钥。外部 provider 连接 WebSocket 时使用每个 Bot 自己的 agb_... token。
AGENT_BRIDGE_ENABLED=true
AGENT_BRIDGE_TOKEN=
# Agent Bridge Bot 前台等待阈值（秒）：超过后转后台 task，provider 可继续长期运行
AGENT_BRIDGE_TIMEOUT_SECONDS=600
# OpenClaw npm package name shown by /docs/agent-bridge/discovery
OPENCLAW_PLUGIN_PACKAGE=@haowei0520/openclaw-channel-agentnexus

# ===== Docker Compose OpenCode Bot（可选）=====
# 启用后，backend seed 会创建一个 Agent Bridge Bot，opencode-bot 容器会用同一个 token 连接。
# 容器内置 OpenCode ACP，支持 ACP 图片输入和嵌入文件上下文；实际图片理解还取决于模型能力。
# 生成示例：python - <<'PY'
# import secrets; print("agb_" + secrets.token_urlsafe(32))
# PY
OPENCODE_BOT_ENABLED=false
OPENCODE_BOT_ID=bot-opencode-001
OPENCODE_BOT_USERNAME=opencode
OPENCODE_BOT_DISPLAY_NAME=OpenCode
OPENCODE_BOT_DESCRIPTION=OpenCode ACP coding assistant
OPENCODE_BOT_SCOPE=everyone
OPENCODE_BOT_TOKEN=
OPENCODE_BOT_IMAGE=47.99.42.4:5000/ai/agentnexus-opencode:latest
OPENCODE_BOT_WS_BASE=ws://backend:8000
OPENCODE_OPENAI_API_KEY=
OPENCODE_OPENAI_BASE_URL=
OPENCODE_PROVIDER=deepseek
OPENCODE_MODEL=
OPENCODE_AGENTNEXUS_APPROVAL_MODE=ask
OPENCODE_NATIVE_PERMISSION_MODE=ask
# Legacy alias for OPENCODE_AGENTNEXUS_APPROVAL_MODE.
OPENCODE_PERMISSION_MODE=
OPENCODE_PROMPT_TIMEOUT_MS=660000
OPENCODE_REQUEST_TIMEOUT_MS=
OPENCODE_WORKSPACE_DIR=/workspace

# ===== SMTP 邮件配置（用于发送注册/重置密码验证码）=====
# 留空则验证码仅打印到日志（开发模式）
# Gmail 示例（需开启两步验证并使用应用专用密码）：
#   SMTP_HOST=smtp.gmail.com  SMTP_PORT=465  SMTP_SSL=true  SMTP_USE_TLS=false
# QQ 邮箱示例（需在设置中开启 SMTP 并获取授权码）：
#   SMTP_HOST=smtp.qq.com     SMTP_PORT=465  SMTP_SSL=true  SMTP_USE_TLS=false
# 163 邮箱示例：
#   SMTP_HOST=smtp.163.com    SMTP_PORT=465  SMTP_SSL=true  SMTP_USE_TLS=false
# 通用 STARTTLS（587 端口）：
#   SMTP_HOST=smtp.example.com  SMTP_PORT=587  SMTP_SSL=false  SMTP_USE_TLS=true
SMTP_HOST=
SMTP_PORT=465
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=
SMTP_USE_TLS=false
SMTP_SSL=true

# ===== 注册邮箱限制（可选）=====
# 正则必须完整匹配注册邮箱；留空表示不限制。示例：只允许 example.com 域名邮箱注册。
REGISTRATION_EMAIL_PATTERN=
# REGISTRATION_EMAIL_PATTERN=^[^@]+@example\.com$
