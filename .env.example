# AgentNexus 环境变量示例
# 复制为 .env 并填写实际值

# Docker 宿主机端口（遇到端口冲突时可修改）
BACKEND_HOST_PORT=8002
FRONTEND_HOST_PORT=80
REDIS_HOST_PORT=6389
POSTGRES_HOST_PORT=5432
RUSTFS_API_HOST_PORT=9000
RUSTFS_CONSOLE_HOST_PORT=9001

# PostgreSQL
POSTGRES_USER=agentnexus
POSTGRES_PASSWORD=agentnexus
POSTGRES_DB=agentnexus

# 数据库（主业务库 PostgreSQL）
DATABASE_URL=postgresql+asyncpg://agentnexus:agentnexus@localhost:5432/agentnexus

# Context Store（四层记忆，默认同主库）
CONTEXT_DB_URL=postgresql+asyncpg://agentnexus:agentnexus@localhost:5432/agentnexus

# Redis（Bot 响应队列等）
REDIS_URL=redis://localhost:6379/0

# 数据根目录（上传、转换、记忆 MD 等）
DATA_DIR=data

# 调试
DEBUG=false

STORAGE_BACKEND=s3
STORAGE_S3_ENDPOINT=http://rustfs:9000
STORAGE_S3_PUBLIC_ENDPOINT=http://localhost:9000
STORAGE_S3_REGION=us-east-1
STORAGE_S3_ACCESS_KEY=change-me-access-key
STORAGE_S3_SECRET_KEY=change-me-secret-key
STORAGE_S3_BUCKET=agentnexus-files
STORAGE_S3_FORCE_PATH_STYLE=true
STORAGE_S3_AUTO_CREATE_BUCKET=true
STORAGE_PRESIGN_EXPIRES_SECONDS=900
FILE_UPLOAD_MAX_BYTES=26214400
FILE_UPLOAD_ALLOWED_TYPES=application/pdf,application/vnd.openxmlformats-officedocument.wordprocessingml.document,text/plain,text/markdown

RUSTFS_ACCESS_KEY=change-me-access-key
RUSTFS_SECRET_KEY=change-me-secret-key
JWT_SECRET_KEY=change-me-jwt-secret

# ===== 初始管理员账号（首次 SEED_DATA=1 启动时创建）=====
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me-admin-password
ADMIN_DISPLAY_NAME=系统管理员

# ===== OpenClaw channel plugin bridge =====
# 共享密钥；plugin 通过 header X-OpenClaw-Token 或 WS ?token=... 鉴权
OPENCLAW_BRIDGE_ENABLED=true
OPENCLAW_BRIDGE_TOKEN=
# WebSocket Bot 派发后等待 plugin 回推的超时（秒）
OPENCLAW_BRIDGE_TIMEOUT_SECONDS=300

# ===== SMTP 邮件配置（用于发送注册/重置密码验证码）=====
# 留空则验证码仅打印到日志（开发模式）
# Gmail 示例（需开启两步验证并使用应用专用密码）：
#   SMTP_HOST=smtp.gmail.com  SMTP_PORT=465  SMTP_SSL=true  SMTP_USE_TLS=false
# QQ 邮箱示例（需在设置中开启 SMTP 并获取授权码）：
#   SMTP_HOST=smtp.qq.com     SMTP_PORT=465  SMTP_SSL=true  SMTP_USE_TLS=false
# 163 邮箱示例：
#   SMTP_HOST=smtp.163.com    SMTP_PORT=465  SMTP_SSL=true  SMTP_USE_TLS=false
# 通用 STARTTLS（587 端口）：
#   SMTP_HOST=smtp.example.com  SMTP_PORT=587  SMTP_SSL=false  SMTP_USE_TLS=true
SMTP_HOST=
SMTP_PORT=465
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=
SMTP_USE_TLS=false
SMTP_SSL=true
