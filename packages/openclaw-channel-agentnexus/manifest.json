{
  "id": "agentnexus",
  "kind": "channel",
  "channels": ["agentnexus"],
  "name": "AgentNexus",
  "description": "Slack-like multi-channel chat with bots. One OpenClaw account = one AgentNexus Agent Bridge Bot.",
  "version": "0.2.4",
  "activation": {
    "onStartup": true,
    "onChannels": ["agentnexus"],
    "onCapabilities": ["channel"]
  },
  "configSchema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "agentnexus": {
        "type": "object",
        "properties": {
          "accounts": {
            "type": "object",
            "additionalProperties": {
              "type": "object",
              "required": ["botToken", "controlUrl", "dataUrl"],
              "properties": {
                "enabled": { "type": "boolean", "default": true },
                "botToken": {
                  "type": "string",
                  "description": "AgentNexus 创建 Agent Bridge Bot 时返回的一次性 token（形如 agb_...）",
                  "x-sensitive": true
                },
                "controlUrl": {
                  "type": "string",
                  "format": "uri",
                  "description": "AgentNexus control WS 地址，例如 ws://localhost:8000/ws/agent-bridge/control"
                },
                "dataUrl": {
                  "type": "string",
                  "format": "uri",
                  "description": "AgentNexus data WS 地址，例如 ws://localhost:8000/ws/agent-bridge/data"
                },
                "advanced": {
                  "type": "object",
                  "properties": {
                    "reconnectBaseMs": { "type": "integer", "default": 1000 },
                    "reconnectMaxMs": { "type": "integer", "default": 30000 },
                    "heartbeatIntervalMs": { "type": "integer", "default": 30000 },
                    "sendAckTimeoutMs": { "type": "integer", "default": 600000 }
                  }
                },
                "outputFallback": {
                  "type": "object",
                  "properties": {
                    "enabled": { "type": "boolean", "default": true },
                    "outputDirs": {
                      "type": "array",
                      "items": { "type": "string" },
                      "default": []
                    },
                    "delayMs": { "type": "integer", "default": 600000 },
                    "pollMs": { "type": "integer", "default": 2000 },
                    "stableMs": { "type": "integer", "default": 6000 },
                    "postStreamWatchMs": { "type": "integer", "default": 15000 },
                    "maxWatchMs": { "type": "integer", "default": 3600000 },
                    "maxFiles": { "type": "integer", "default": 80 },
                    "minBytes": { "type": "integer", "default": 16 },
                    "maxBytes": { "type": "integer", "default": 26214400 }
                  }
                }
              }
            }
          }
        }
      }
    }
  }
}
