{
  "name": "openclaw-channel-agentnexus",
  "version": "0.1.0",
  "description": "OpenClaw channel plugin for AgentNexus — connects an OpenClaw agent to AgentNexus via the per-bot control + data WebSocket bridge.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./setup-entry": {
      "types": "./dist/setup-entry.d.ts",
      "import": "./dist/setup-entry.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc -p tsconfig.json --noEmit",
    "demo": "tsx src/demo.ts"
  },
  "keywords": ["openclaw", "channel", "plugin", "agentnexus", "websocket"],
  "license": "MIT",
  "dependencies": {
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/node": "^22.9.0",
    "@types/ws": "^8.5.13",
    "tsx": "^4.19.2",
    "typescript": "~5.6.2",
    "vitest": "^2.1.4"
  },
  "openclaw": {
    "extensions": ["./dist/index.js"],
    "setupEntry": "./dist/setup-entry.js",
    "channel": {
      "id": "agentnexus",
      "label": "AgentNexus",
      "blurb": "Slack-like multi-channel chat with bots (via bridge WS)"
    }
  }
}
