{
  "id": "agentnexus",
  "kind": "channel",
  "name": "AgentNexus",
  "description": "Slack-like multi-channel chat with bots. One OpenClaw account = one AgentNexus Agent Bridge Bot.",
  "version": "0.2.4",
  "activation": {
    "onStartup": true,
    "onChannels": [
      "agentnexus"
    ],
    "onCapabilities": [
      "channel"
    ]
  },
  "channels": [
    "agentnexus"
  ],
  "channelEnvVars": {
    "agentnexus": [
      "AGENTNEXUS_BOT_TOKEN",
      "AGENTNEXUS_CONTROL_URL",
      "AGENTNEXUS_DATA_URL"
    ]
  },
  "channelConfigs": {
    "agentnexus": {
      "label": "AgentNexus",
      "description": "Connect to AgentNexus via per-bot WebSocket bridge. One account = one AgentNexus Agent Bridge Bot.",
      "schema": {
        "$schema": "http://json-schema.org/draft-07/schema#",
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "enabled": { "type": "boolean", "default": true },
          "accounts": {
            "type": "object",
            "additionalProperties": {
              "type": "object",
              "required": ["botToken", "controlUrl", "dataUrl"],
              "additionalProperties": false,
              "properties": {
                "enabled": { "type": "boolean", "default": true },
                "botToken": {
                  "type": "string",
                  "description": "Per-bot token issued by AgentNexus when the Agent Bridge Bot is created (agb_...)."
                },
                "controlUrl": {
                  "type": "string",
                  "description": "AgentNexus control WS URL, e.g. ws://localhost:8000/ws/agent-bridge/control"
                },
                "dataUrl": {
                  "type": "string",
                  "description": "AgentNexus data WS URL, e.g. ws://localhost:8000/ws/agent-bridge/data"
                },
                "advanced": {
                  "type": "object",
                  "additionalProperties": false,
                  "properties": {
                    "reconnectBaseMs": { "type": "integer", "default": 1000 },
                    "reconnectMaxMs": { "type": "integer", "default": 30000 },
                    "heartbeatIntervalMs": { "type": "integer", "default": 30000 },
                    "sendAckTimeoutMs": { "type": "integer", "default": 600000 }
                  }
                },
                "outputFallback": {
                  "type": "object",
                  "additionalProperties": false,
                  "properties": {
                    "enabled": { "type": "boolean", "default": true },
                    "outputDirs": {
                      "type": "array",
                      "items": { "type": "string" },
                      "default": []
                    },
                    "delayMs": { "type": "integer", "default": 600000 },
                    "pollMs": { "type": "integer", "default": 2000 },
                    "stableMs": { "type": "integer", "default": 6000 },
                    "postStreamWatchMs": { "type": "integer", "default": 15000 },
                    "maxWatchMs": { "type": "integer", "default": 3600000 },
                    "maxFiles": { "type": "integer", "default": 80 },
                    "minBytes": { "type": "integer", "default": 16 },
                    "maxBytes": { "type": "integer", "default": 26214400 }
                  }
                }
              }
            }
          }
        }
      }
    }
  },
  "configSchema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "agentnexus": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "accounts": {
            "type": "object",
            "additionalProperties": {
              "type": "object",
              "required": ["botToken", "controlUrl", "dataUrl"],
              "properties": {
                "enabled": { "type": "boolean", "default": true },
                "botToken": { "type": "string" },
                "controlUrl": { "type": "string" },
                "dataUrl": { "type": "string" },
                "advanced": {
                  "type": "object",
                  "properties": {
                    "reconnectBaseMs": { "type": "integer", "default": 1000 },
                    "reconnectMaxMs": { "type": "integer", "default": 30000 },
                    "heartbeatIntervalMs": { "type": "integer", "default": 30000 },
                    "sendAckTimeoutMs": { "type": "integer", "default": 600000 }
                  }
                },
                "outputFallback": {
                  "type": "object",
                  "properties": {
                    "enabled": { "type": "boolean", "default": true },
                    "outputDirs": {
                      "type": "array",
                      "items": { "type": "string" },
                      "default": []
                    },
                    "delayMs": { "type": "integer", "default": 600000 },
                    "pollMs": { "type": "integer", "default": 2000 },
                    "stableMs": { "type": "integer", "default": 6000 },
                    "postStreamWatchMs": { "type": "integer", "default": 15000 },
                    "maxWatchMs": { "type": "integer", "default": 3600000 },
                    "maxFiles": { "type": "integer", "default": 80 },
                    "minBytes": { "type": "integer", "default": 16 },
                    "maxBytes": { "type": "integer", "default": 26214400 }
                  }
                }
              }
            }
          }
        }
      }
    }
  }
}
