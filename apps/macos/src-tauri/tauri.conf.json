{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Cheers",
  "version": "0.1.3",
  "identifier": "com.cheers.macos",
  "build": {
    "beforeDevCommand": "npm --prefix ../../frontend run dev",
    "devUrl": "http://localhost:5173",
    "beforeBuildCommand": "npm --prefix ../../frontend run build",
    "frontendDist": "../../../frontend/dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Cheers",
        "width": 1280,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600
      },
      {
        "label": "quickpanel",
        "title": "Cheers Quick Panel",
        "url": "index.html?quickpanel=1",
        "width": 560,
        "height": 340,
        "resizable": false,
        "decorations": false,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "visible": false,
        "center": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob: https: http:; media-src 'self' blob: https: http:; font-src 'self' data:; connect-src 'self' ipc: http://ipc.localhost tauri://localhost http://tauri.localhost https: http: ws: wss:; object-src 'none'; base-uri 'self'; frame-ancestors 'none'"
    }
  },
  "plugins": {
    "deep-link": {
      "desktop": {
        "schemes": ["cheers"]
      }
    },
    "updater": {
      "endpoints": [
        "https://github.com/ElePerson/Cheers/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDVFREExMTc2QjA2NkIwMTIKUldRU3NHYXdkaEhhWGhVREVPSGZJZ2VGMEszM1lCZWx2WTBoWjFwY28vY0VCTmVodkFUMlNrMXAK"
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": ["app", "dmg"],
    "icon": ["icons/icon.icns", "icons/icon.png"],
    "externalBin": ["binaries/cce-acp-connector", "binaries/cheers-mcp-server"],
    "fileAssociations": [
      {
        "ext": ["png", "jpg", "jpeg", "gif", "webp", "pdf", "txt", "md"],
        "name": "Cheers Attachment",
        "description": "Send to Cheers",
        "role": "Viewer"
      }
    ],
    "macOS": {
      "minimumSystemVersion": "12.0",
      "infoPlist": "Info.plist"
    }
  }
}
