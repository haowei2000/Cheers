services:
  gateway:
    build:
      context: ./server
    restart: unless-stopped
    ports:
      - "${GATEWAY_HOST_PORT:-8000}:8000"
    env_file:
      - .env
    environment:
      # sqlx 用纯 postgres:// （非 SQLAlchemy 的 +asyncpg）
      - DATABASE_URL=postgresql://${POSTGRES_USER:-agentnexus}:${POSTGRES_PASSWORD:-agentnexus}@postgres:5432/${POSTGRES_DB:-agentnexus}
      - PORT=8000
      - REDIS_URL=redis://redis:6379/0
      # JWT RS256：必填，由 .env 提供（缺失则 gateway 启动 panic）
      - JWT_PRIVATE_KEY=${JWT_PRIVATE_KEY:-}
      - JWT_PUBLIC_KEY=${JWT_PUBLIC_KEY:-}
      - JWT_SECRET_KEY=${JWT_SECRET_KEY:-}
      # S3 / RustFS
      - S3_ENDPOINT=http://rustfs:9000
      - S3_BUCKET=${STORAGE_S3_BUCKET:-agentnexus-files}
      - S3_ACCESS_KEY=${RUSTFS_ACCESS_KEY:-agentnexus-local-access-key}
      - S3_SECRET_KEY=${RUSTFS_SECRET_KEY:-agentnexus-local-secret-key}
      # SMTP（可选）
      - SMTP_HOST=${SMTP_HOST:-}
      - SMTP_PORT=${SMTP_PORT:-587}
      - SMTP_USERNAME=${SMTP_USERNAME:-}
      - SMTP_PASSWORD=${SMTP_PASSWORD:-}
    depends_on:
      postgres:
        condition: service_healthy
      redis:
        condition: service_started
      rustfs:
        condition: service_healthy
    healthcheck:
      test: ["CMD-SHELL", "curl -fsS http://127.0.0.1:8000/health || exit 1"]
      interval: 10s
      timeout: 5s
      retries: 12
      start_period: 20s

  opencode-bot:
    image: ${OPENCODE_BOT_IMAGE:-registry.example.invalid:5000/ai/agentnexus-opencode:latest}
    restart: unless-stopped
    env_file:
      - .env
    environment:
      - AGENTNEXUS_WS_BASE=${OPENCODE_BOT_WS_BASE:-ws://gateway:8000}
      - OPENCODE_BOT_USERNAME=${OPENCODE_BOT_USERNAME:-opencode}
      - OPENCODE_BOT_TOKEN=${OPENCODE_BOT_TOKEN:-}
      - OPENCODE_OPENAI_API_KEY=${OPENCODE_OPENAI_API_KEY:-}
      - OPENCODE_OPENAI_BASE_URL=${OPENCODE_OPENAI_BASE_URL:-}
      - OPENCODE_PROVIDER=${OPENCODE_PROVIDER:-deepseek}
      - OPENCODE_MODEL=${OPENCODE_MODEL:-}
      - OPENCODE_WORKSPACE_DIR=${OPENCODE_WORKSPACE_DIR:-/workspace}
      - OPENCODE_AGENTNEXUS_APPROVAL_MODE=${OPENCODE_AGENTNEXUS_APPROVAL_MODE:-}
      - OPENCODE_NATIVE_PERMISSION_MODE=${OPENCODE_NATIVE_PERMISSION_MODE:-ask}
      - OPENCODE_PERMISSION_MODE=${OPENCODE_PERMISSION_MODE:-}
      - OPENCODE_PROMPT_TIMEOUT_MS=${OPENCODE_PROMPT_TIMEOUT_MS:-660000}
      - OPENCODE_REQUEST_TIMEOUT_MS=${OPENCODE_REQUEST_TIMEOUT_MS:-}
    volumes:
      - ./data/opencode-bot:/app/state
      - ./data/opencode-workspace:/workspace
    depends_on:
      gateway:
        condition: service_healthy

  # db-migrate 服务已移除：gateway 启动时自动跑 sqlx 迁移（main.rs: sqlx::migrate!）。

  frontend:
    build: ./frontend
    restart: unless-stopped
    ports:
      - "${FRONTEND_HOST_PORT:-80}:80"
    depends_on:
      - gateway
      - kkfileview

  kkfileview:
    image: ${KKFILEVIEW_IMAGE:-keking/kkfileview:latest}
    restart: unless-stopped
    ports:
      - "${KKFILEVIEW_HOST_BIND:-127.0.0.1}:${KKFILEVIEW_HOST_PORT:-8012}:8012"
    environment:
      - KK_CONTEXT_PATH=/preview
      - KK_BASE_URL=${KKFILEVIEW_BASE_URL:-http://localhost/preview}
      - KK_TRUST_HOST=${KKFILEVIEW_TRUST_HOST:-localhost}
      - KK_FILE_DIR=${KKFILEVIEW_FILE_DIR:-/opt/kkfileview/file/}
      - KK_OFFICE_PREVIEW_TYPE=${KKFILEVIEW_OFFICE_PREVIEW_TYPE:-pdf}
      - KK_PDF_DOWNLOAD_DISABLE=${KKFILEVIEW_PDF_DOWNLOAD_DISABLE:-true}
      - KK_PDF_PRINT_DISABLE=${KKFILEVIEW_PDF_PRINT_DISABLE:-true}
      - KK_MEDIA_CONVERT_DISABLE=${KKFILEVIEW_MEDIA_CONVERT_DISABLE:-true}
    volumes:
      - ./data/kkfileview:/opt/kkfileview/file

  postgres:
    image: postgres:16-alpine
    restart: unless-stopped
    ports:
      - "${POSTGRES_HOST_PORT:-5432}:5432"
    environment:
      - POSTGRES_USER=${POSTGRES_USER:-agentnexus}
      - POSTGRES_PASSWORD=${POSTGRES_PASSWORD:-agentnexus}
      - POSTGRES_DB=${POSTGRES_DB:-agentnexus}
    volumes:
      - ./data/postgres:/var/lib/postgresql/data
    healthcheck:
      test: ["CMD-SHELL", "pg_isready -U ${POSTGRES_USER:-agentnexus}"]
      interval: 5s
      timeout: 5s
      retries: 10

  redis:
    image: redis:7-alpine
    restart: unless-stopped

  rustfs:
    image: rustfs/rustfs:latest
    restart: unless-stopped
    security_opt:
      - "no-new-privileges:true"
    ports:
      - "${RUSTFS_API_HOST_PORT:-9000}:9000"
      - "${RUSTFS_CONSOLE_HOST_PORT:-9001}:9001"
    environment:
      - RUSTFS_VOLUMES=/data
      - RUSTFS_ADDRESS=0.0.0.0:9000
      - RUSTFS_CONSOLE_ADDRESS=0.0.0.0:9001
      - RUSTFS_CONSOLE_ENABLE=true
      - RUSTFS_CORS_ALLOWED_ORIGINS=${RUSTFS_CORS_ALLOWED_ORIGINS:-*}
      - RUSTFS_CONSOLE_CORS_ALLOWED_ORIGINS=${RUSTFS_CONSOLE_CORS_ALLOWED_ORIGINS:-*}
      - RUSTFS_ACCESS_KEY=${RUSTFS_ACCESS_KEY:-agentnexus-local-access-key}
      - RUSTFS_SECRET_KEY=${RUSTFS_SECRET_KEY:-agentnexus-local-secret-key}
      - RUSTFS_OBS_LOGGER_LEVEL=${RUSTFS_OBS_LOGGER_LEVEL:-info}
      - RUSTFS_OBJECT_CACHE_ENABLE=${RUSTFS_OBJECT_CACHE_ENABLE:-true}
      - RUSTFS_OBJECT_CACHE_TTL_SECS=${RUSTFS_OBJECT_CACHE_TTL_SECS:-300}
    volumes:
      - ./data/rustfs:/data
      - ./data/rustfs_logs:/logs
    healthcheck:
      test: ["CMD-SHELL", "wget -S -O /dev/null http://127.0.0.1:9000/rustfs/health/live 2>&1 | grep -Eq 'HTTP/[0-9.]+ (200|403)'"]
      interval: 5s
      timeout: 5s
      retries: 20
      start_period: 10s
