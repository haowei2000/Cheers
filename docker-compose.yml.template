services:
  backend:
    build:
      context: ./backend
      args:
        PIP_INDEX_URL: ${BACKEND_PIP_INDEX_URL:-https://pypi.org/simple}
    restart: unless-stopped
    extra_hosts:
      - "host.docker.internal:host-gateway"
    ports:
      - "${BACKEND_HOST_PORT:-8002}:8000"
    environment:
      - DATABASE_URL=sqlite+aiosqlite:///data/main.db
      - REDIS_URL=redis://redis:6379/0
      - SQLITE_CONTEXT_PATH=data/context_store/context.db
      - DATA_DIR=data
      - STORAGE_BACKEND=${STORAGE_BACKEND:-s3}
      - STORAGE_S3_ENDPOINT=${STORAGE_S3_ENDPOINT:-http://rustfs:9000}
      - STORAGE_S3_PUBLIC_ENDPOINT=${STORAGE_S3_PUBLIC_ENDPOINT:-http://localhost:9000}
      - STORAGE_S3_REGION=${STORAGE_S3_REGION:-us-east-1}
      - STORAGE_S3_ACCESS_KEY=${STORAGE_S3_ACCESS_KEY:-agentnexus-dev-access}
      - STORAGE_S3_SECRET_KEY=${STORAGE_S3_SECRET_KEY:-agentnexus-dev-secret}
      - STORAGE_S3_BUCKET=${STORAGE_S3_BUCKET:-agentnexus-files}
      - STORAGE_S3_FORCE_PATH_STYLE=${STORAGE_S3_FORCE_PATH_STYLE:-true}
      - STORAGE_S3_AUTO_CREATE_BUCKET=${STORAGE_S3_AUTO_CREATE_BUCKET:-true}
      - STORAGE_PRESIGN_EXPIRES_SECONDS=${STORAGE_PRESIGN_EXPIRES_SECONDS:-900}
      - FILE_UPLOAD_MAX_BYTES=${FILE_UPLOAD_MAX_BYTES:-26214400}
      - FILE_UPLOAD_ALLOWED_TYPES=${FILE_UPLOAD_ALLOWED_TYPES:-application/pdf,application/vnd.openxmlformats-officedocument.wordprocessingml.document,text/plain,image/png,image/jpeg,image/webp,image/gif}
      - LLM_LOCALHOST_ALIAS=${LLM_LOCALHOST_ALIAS:-host.docker.internal}
      - IMAGE_GEN_BASE_URL=${IMAGE_GEN_BASE_URL:-https://dashscope.aliyuncs.com/compatible-mode/v1}
      - IMAGE_GEN_API_KEY=${IMAGE_GEN_API_KEY:-}
      - IMAGE_GEN_DEFAULT_MODEL=${IMAGE_GEN_DEFAULT_MODEL:-qwen-image-2.0-pro}
      - SEED_DATA=${SEED_DATA:-1}
    volumes:
      - agentnexus_data:/app/data
    depends_on:
      redis:
        condition: service_started
      rustfs:
        condition: service_started

  frontend:
    build: ./frontend
    restart: unless-stopped
    ports:
      - "${FRONTEND_HOST_PORT:-80}:80"
    depends_on:
      - backend

  redis:
    image: redis:7-alpine
    restart: unless-stopped
    ports:
      - "${REDIS_HOST_PORT:-6389}:6379"

  rustfs:
    image: rustfs/rustfs:latest
    restart: unless-stopped
    security_opt:
      - "no-new-privileges:true"
    ports:
      - "${RUSTFS_API_HOST_PORT:-9000}:9000"
      - "${RUSTFS_CONSOLE_HOST_PORT:-9001}:9001"
    environment:
      - RUSTFS_VOLUMES=/data
      - RUSTFS_ADDRESS=0.0.0.0:9000
      - RUSTFS_CONSOLE_ADDRESS=0.0.0.0:9001
      - RUSTFS_CONSOLE_ENABLE=true
      - RUSTFS_CORS_ALLOWED_ORIGINS=${RUSTFS_CORS_ALLOWED_ORIGINS:-*}
      - RUSTFS_CONSOLE_CORS_ALLOWED_ORIGINS=${RUSTFS_CONSOLE_CORS_ALLOWED_ORIGINS:-*}
      - RUSTFS_ACCESS_KEY=${RUSTFS_ACCESS_KEY:-agentnexus-dev-access}
      - RUSTFS_SECRET_KEY=${RUSTFS_SECRET_KEY:-agentnexus-dev-secret}
      - RUSTFS_OBS_LOGGER_LEVEL=${RUSTFS_OBS_LOGGER_LEVEL:-info}
      - RUSTFS_OBJECT_CACHE_ENABLE=${RUSTFS_OBJECT_CACHE_ENABLE:-true}
      - RUSTFS_OBJECT_CACHE_TTL_SECS=${RUSTFS_OBJECT_CACHE_TTL_SECS:-300}
    volumes:
      - rustfs_data:/data
      - rustfs_logs:/logs
    healthcheck:
      test: ["CMD", "sh", "-c", "curl -f http://127.0.0.1:9000/health && curl -f http://127.0.0.1:9001/health"]
      interval: 30s
      timeout: 10s
      retries: 3
      start_period: 40s

volumes:
  agentnexus_data:
  rustfs_data:
  rustfs_logs:
