services:
  backend:
    build:
      context: ./backend
    restart: unless-stopped
    ports:
      - "${BACKEND_HOST_PORT:-8000}:8000"
    env_file:
      - .env
    environment:
      - DATABASE_URL=postgresql+asyncpg://${POSTGRES_USER:-agentnexus}:${POSTGRES_PASSWORD:-agentnexus}@postgres:5432/${POSTGRES_DB:-agentnexus}
      - CONTEXT_DB_URL=postgresql+asyncpg://${POSTGRES_USER:-agentnexus}:${POSTGRES_PASSWORD:-agentnexus}@postgres:5432/${POSTGRES_DB:-agentnexus}
      - REDIS_URL=redis://redis:6379/0
      - DATA_DIR=data
      - STORAGE_BACKEND=${STORAGE_BACKEND:-s3}
      - STORAGE_S3_ENDPOINT=http://rustfs:9000
      - STORAGE_S3_PUBLIC_ENDPOINT=${STORAGE_S3_PUBLIC_ENDPOINT:-http://localhost:9000}
      - STORAGE_S3_REGION=${STORAGE_S3_REGION:-us-east-1}
      - STORAGE_S3_ACCESS_KEY=${RUSTFS_ACCESS_KEY:-admin}
      - STORAGE_S3_SECRET_KEY=${RUSTFS_SECRET_KEY:-123456}
      - STORAGE_S3_BUCKET=${STORAGE_S3_BUCKET:-agentnexus-files}
      - STORAGE_S3_FORCE_PATH_STYLE=${STORAGE_S3_FORCE_PATH_STYLE:-true}
      - STORAGE_S3_AUTO_CREATE_BUCKET=${STORAGE_S3_AUTO_CREATE_BUCKET:-true}
      - STORAGE_S3_VERIFY_SSL=${STORAGE_S3_VERIFY_SSL:-true}
      - STORAGE_PRESIGN_EXPIRES_SECONDS=${STORAGE_PRESIGN_EXPIRES_SECONDS:-900}
      - FILE_UPLOAD_MAX_BYTES=${FILE_UPLOAD_MAX_BYTES:-26214400}
      - FILE_UPLOAD_ALLOWED_TYPES=${FILE_UPLOAD_ALLOWED_TYPES:-application/pdf,application/vnd.openxmlformats-officedocument.wordprocessingml.document,text/plain,text/markdown,image/png,image/jpeg,image/webp,image/gif}
      - LLM_LOCALHOST_ALIAS=${LLM_LOCALHOST_ALIAS:-host.docker.internal}
      - HELPER_LLM_BASE_URL=${HELPER_LLM_BASE_URL:-}
      - HELPER_LLM_MODEL=${HELPER_LLM_MODEL:-}
      - HELPER_LLM_API_KEY=${HELPER_LLM_API_KEY:-}
      - HELPER_LLM_TEMPERATURE=${HELPER_LLM_TEMPERATURE:-0.7}
      - HELPER_LLM_MAX_TOKENS=${HELPER_LLM_MAX_TOKENS:-1000}
      - AGENT_BRIDGE_ENABLED=${AGENT_BRIDGE_ENABLED:-true}
      - AGENT_BRIDGE_TOKEN=${AGENT_BRIDGE_TOKEN:-}
      - AGENT_BRIDGE_TIMEOUT_SECONDS=${AGENT_BRIDGE_TIMEOUT_SECONDS:-600}
      - OPENCLAW_PLUGIN_PACKAGE=${OPENCLAW_PLUGIN_PACKAGE:-@haowei0520/openclaw-channel-agentnexus}
      - OPENCLAW_PLUGIN_RELEASE_DIR=${OPENCLAW_PLUGIN_RELEASE_DIR:-/app/release}
      - OPENCLAW_PLUGIN_FILE=${OPENCLAW_PLUGIN_FILE:-openclaw-channel-agentnexus.tgz}
      - DB_MIGRATION_MODE=${DB_MIGRATION_MODE:-upgrade}
      - DB_MIGRATION_TARGET=${DB_MIGRATION_TARGET:-head}
      - CONTEXT_DB_MIGRATION_MODE=${CONTEXT_DB_MIGRATION_MODE:-upgrade}
      - CONTEXT_DB_MIGRATION_TARGET=${CONTEXT_DB_MIGRATION_TARGET:-head}
      - ALLOW_DB_DOWNGRADE=${ALLOW_DB_DOWNGRADE:-0}
      - SEED_DATA=${SEED_DATA:-1}
    volumes:
      - ./data/backend:/app/data
      - ./release:/app/release:ro
    depends_on:
      postgres:
        condition: service_healthy
      redis:
        condition: service_started
      rustfs:
        condition: service_healthy

  db-migrate:
    build:
      context: ./backend
    profiles:
      - tools
    restart: "no"
    env_file:
      - .env
    environment:
      - DATABASE_URL=postgresql+asyncpg://${POSTGRES_USER:-agentnexus}:${POSTGRES_PASSWORD:-agentnexus}@postgres:5432/${POSTGRES_DB:-agentnexus}
      - CONTEXT_DB_URL=postgresql+asyncpg://${POSTGRES_USER:-agentnexus}:${POSTGRES_PASSWORD:-agentnexus}@postgres:5432/${POSTGRES_DB:-agentnexus}
      - MIGRATE_ONLY=${MIGRATE_ONLY:-1}
      - DB_MIGRATION_MODE=${DB_MIGRATION_MODE:-upgrade}
      - DB_MIGRATION_TARGET=${DB_MIGRATION_TARGET:-head}
      - CONTEXT_DB_MIGRATION_MODE=${CONTEXT_DB_MIGRATION_MODE:-upgrade}
      - CONTEXT_DB_MIGRATION_TARGET=${CONTEXT_DB_MIGRATION_TARGET:-head}
      - ALLOW_DB_DOWNGRADE=${ALLOW_DB_DOWNGRADE:-0}
    depends_on:
      postgres:
        condition: service_healthy

  frontend:
    build: ./frontend
    restart: unless-stopped
    ports:
      - "${FRONTEND_HOST_PORT:-80}:80"
    depends_on:
      - backend

  postgres:
    image: postgres:16-alpine
    restart: unless-stopped
    environment:
      - POSTGRES_USER=${POSTGRES_USER:-agentnexus}
      - POSTGRES_PASSWORD=${POSTGRES_PASSWORD:-agentnexus}
      - POSTGRES_DB=${POSTGRES_DB:-agentnexus}
    volumes:
      - ./data/postgres:/var/lib/postgresql/data
    healthcheck:
      test: ["CMD-SHELL", "pg_isready -U ${POSTGRES_USER:-agentnexus}"]
      interval: 5s
      timeout: 5s
      retries: 10

  redis:
    image: redis:7-alpine
    restart: unless-stopped

  rustfs:
    image: rustfs/rustfs:latest
    restart: unless-stopped
    security_opt:
      - "no-new-privileges:true"
    ports:
      - "${RUSTFS_API_HOST_PORT:-9000}:9000"
      - "${RUSTFS_CONSOLE_HOST_PORT:-9001}:9001"
    environment:
      - RUSTFS_VOLUMES=/data
      - RUSTFS_ADDRESS=0.0.0.0:9000
      - RUSTFS_CONSOLE_ADDRESS=0.0.0.0:9001
      - RUSTFS_CONSOLE_ENABLE=true
      - RUSTFS_CORS_ALLOWED_ORIGINS=${RUSTFS_CORS_ALLOWED_ORIGINS:-*}
      - RUSTFS_CONSOLE_CORS_ALLOWED_ORIGINS=${RUSTFS_CONSOLE_CORS_ALLOWED_ORIGINS:-*}
      - RUSTFS_ACCESS_KEY=${RUSTFS_ACCESS_KEY:-agentnexus-dev-access}
      - RUSTFS_SECRET_KEY=${RUSTFS_SECRET_KEY:-agentnexus-dev-secret}
      - RUSTFS_OBS_LOGGER_LEVEL=${RUSTFS_OBS_LOGGER_LEVEL:-info}
      - RUSTFS_OBJECT_CACHE_ENABLE=${RUSTFS_OBJECT_CACHE_ENABLE:-true}
      - RUSTFS_OBJECT_CACHE_TTL_SECS=${RUSTFS_OBJECT_CACHE_TTL_SECS:-300}
    volumes:
      - ./data/rustfs:/data
      - ./data/rustfs_logs:/logs
    healthcheck:
      test: ["CMD-SHELL", "wget -q -O /dev/null http://127.0.0.1:9000/health"]
      interval: 5s
      timeout: 5s
      retries: 20
      start_period: 10s
