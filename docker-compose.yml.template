services:
  gateway:
    build:
      context: .
      dockerfile: server/Dockerfile
    restart: unless-stopped
    # Resource caps (single-host defaults; raise for heavier workloads).
    deploy:
      resources:
        limits:
          cpus: "2"
          memory: 1G
        reservations:
          memory: 256M
    ports:
      # Loopback-only: the frontend nginx is the sole external ingress (it
      # proxies /api + /ws and stamps X-Real-IP). Exposing :8000 to the world
      # would let clients bypass the proxy and spoof rate-limit headers. The
      # localhost bind still serves same-host connectors (ws://localhost:8000)
      # and local debugging; set BACKEND_HOST_BIND=0.0.0.0 ONLY if you accept
      # header spoofing and also set TRUST_PROXY_HEADERS=false.
      - "${BACKEND_HOST_BIND:-127.0.0.1}:${GATEWAY_HOST_PORT:-8000}:8000"
    env_file:
      - .env
    environment:
      # sqlx 用纯 postgres:// （非 SQLAlchemy 的 +asyncpg）
      - DATABASE_URL=postgresql://${POSTGRES_USER:-cheers}:${POSTGRES_PASSWORD:-cheers}@postgres:5432/${POSTGRES_DB:-cheers}
      - PORT=8000
      - REDIS_URL=redis://redis:6379/0
      - CORS_ALLOWED_ORIGINS=${CORS_ALLOWED_ORIGINS:-https://cheers.example.com}
      # JWT RS256：必填，由 .env 提供（缺失则 gateway 启动 panic）
      - JWT_PRIVATE_KEY=${JWT_PRIVATE_KEY:-}
      - JWT_PUBLIC_KEY=${JWT_PUBLIC_KEY:-}
      # S3 / RustFS
      - S3_ENDPOINT=${STORAGE_S3_ENDPOINT:-http://rustfs:9000}
      - S3_BUCKET=${STORAGE_S3_BUCKET:-cheers-files}
      - S3_ACCESS_KEY=${STORAGE_S3_ACCESS_KEY:-cheers-local-access-key}
      - S3_SECRET_KEY=${STORAGE_S3_SECRET_KEY:-cheers-local-secret-key}
      # Office→PDF preview conversion (Gotenberg)
      - GOTENBERG_URL=${GOTENBERG_URL:-http://gotenberg:3000}
      # 限流客户端识别：gateway 端口只绑定宿主机 loopback（见上），外部流量一律
      # 经 frontend nginx（它覆写 X-Real-IP）→ 代理头可信、且是区分真实客户端 IP
      # 的唯一途径 → true。若你把 BACKEND_HOST_BIND 改成 0.0.0.0（gateway 可被
      # 直连），必须同时把这里改为 false，否则限流可被伪造头绕过。
      - TRUST_PROXY_HEADERS=${TRUST_PROXY_HEADERS:-true}
      # 自助注册默认关闭（安全默认）；公开实例显式设为 true。
      - OPEN_REGISTRATION=${OPEN_REGISTRATION:-false}
      # 系统级安全策略：远程 Agent 创建和会话启动默认要求用户已开启 2FA。
      - REQUIRE_2FA_FOR_REMOTE_AGENT_ACCESS=${REQUIRE_2FA_FOR_REMOTE_AGENT_ACCESS:-true}
      # Official hosted service only: all four values enable Sign in with Apple.
      # Leave blank on ordinary self-hosted instances; capability discovery then
      # keeps the native Apple button hidden.
      - APPLE_TEAM_ID=${APPLE_TEAM_ID:-}
      - APPLE_KEY_ID=${APPLE_KEY_ID:-}
      - APPLE_CLIENT_ID=${APPLE_CLIENT_ID:-}
      - APPLE_PRIVATE_KEY_P8=${APPLE_PRIVATE_KEY_P8:-}
      - APPLE_WEB_CLIENT_ID=${APPLE_WEB_CLIENT_ID:-}
      - APPLE_WEB_REDIRECT_URI=${APPLE_WEB_REDIRECT_URI:-}
      - GOOGLE_WEB_CLIENT_ID=${GOOGLE_WEB_CLIENT_ID:-}
      - GOOGLE_WEB_CLIENT_SECRET=${GOOGLE_WEB_CLIENT_SECRET:-}
      - GOOGLE_WEB_REDIRECT_URI=${GOOGLE_WEB_REDIRECT_URI:-}
      - OAUTH_WEB_RETURN_URL=${OAUTH_WEB_RETURN_URL:-}
      # Connector self-update: the release version this gateway advertises in
      # its hello + serves via /api/v1/connector/download. Unset ⇒ no update
      # signal (download proxy then tracks the latest GitHub release).
      - CHEERS_CONNECTOR_RELEASE_REPO=${CHEERS_CONNECTOR_RELEASE_REPO:-}
      - CHEERS_CONNECTOR_RELEASE_VERSION=${CHEERS_CONNECTOR_RELEASE_VERSION:-}
      # Real-time voice control plane. LIVEKIT_URL is browser-reachable (wss),
      # while the key/secret stay gateway-only and sign room-scoped join tokens.
      - LIVEKIT_URL=${LIVEKIT_URL:-}
      - LIVEKIT_INTERNAL_URL=${LIVEKIT_INTERNAL_URL:-}
      - LIVEKIT_API_KEY=${LIVEKIT_API_KEY:-}
      - LIVEKIT_API_SECRET=${LIVEKIT_API_SECRET:-}
      - VOICE_TRANSCRIBER_TOKEN=${VOICE_TRANSCRIBER_TOKEN:-}
      # SMTP（可选）
      - SMTP_HOST=${SMTP_HOST:-}
      - SMTP_PORT=${SMTP_PORT:-587}
      - SMTP_USERNAME=${SMTP_USERNAME:-}
      - SMTP_PASSWORD=${SMTP_PASSWORD:-}
    depends_on:
      postgres:
        condition: service_healthy
      redis:
        condition: service_started
      rustfs:
        condition: service_healthy
      gotenberg:
        condition: service_started
    healthcheck:
      test: ["CMD-SHELL", "curl -fsS http://127.0.0.1:8000/health || exit 1"]
      interval: 10s
      timeout: 5s
      retries: 12
      start_period: 20s

  # Optional agent bot. It needs an Agent Bridge token that can only be minted
  # from a running gateway, so it is NOT started by `docker compose up -d`. Bring
  # up the core stack first, mint a token (see the Docker Compose deploy guide),
  # put it in OPENCODE_BOT_TOKEN, then start this with:
  #   docker compose --profile bot up -d opencode-bot
  opencode-bot:
    profiles: ["bot"]
    build:
      context: .
      dockerfile: docker/opencode-bot/Dockerfile
    image: ${OPENCODE_BOT_IMAGE:-cheers/opencode-bot:latest}
    restart: unless-stopped
    # The agent runtime (node + ACP) is the heaviest workload — allow more headroom.
    deploy:
      resources:
        limits:
          cpus: "2"
          memory: 2G
        reservations:
          memory: 256M
    env_file:
      - .env
    environment:
      - CHEERS_WS_BASE=${OPENCODE_BOT_WS_BASE:-ws://gateway:8000}
      - OPENCODE_BOT_USERNAME=${OPENCODE_BOT_USERNAME:-opencode}
      - OPENCODE_BOT_TOKEN=${OPENCODE_BOT_TOKEN:-}
      - OPENCODE_OPENAI_API_KEY=${OPENCODE_OPENAI_API_KEY:-}
      - OPENCODE_OPENAI_BASE_URL=${OPENCODE_OPENAI_BASE_URL:-}
      - OPENCODE_PROVIDER=${OPENCODE_PROVIDER:-deepseek}
      - OPENCODE_MODEL=${OPENCODE_MODEL:-}
      - OPENCODE_WORKSPACE_DIR=${OPENCODE_WORKSPACE_DIR:-/workspace}
      - OPENCODE_NATIVE_PERMISSION_MODE=${OPENCODE_NATIVE_PERMISSION_MODE:-ask}
      - OPENCODE_PROMPT_TIMEOUT_MS=${OPENCODE_PROMPT_TIMEOUT_MS:-660000}
      - OPENCODE_REQUEST_TIMEOUT_MS=${OPENCODE_REQUEST_TIMEOUT_MS:-}
    volumes:
      - ./data/opencode-bot:/app/state
      - ./data/opencode-workspace:/workspace
    depends_on:
      gateway:
        condition: service_healthy

  # Optional streaming STT worker. Keep this compute workload off the small
  # dedicated LiveKit SFU host; it connects outbound to LiveKit and the gateway.
  voice-transcriber:
    profiles: ["voice-transcriber"]
    build:
      context: ./services/voice-transcriber
    image: ${VOICE_TRANSCRIBER_IMAGE:-cheers/voice-transcriber:latest}
    restart: unless-stopped
    deploy:
      resources:
        limits:
          cpus: "2"
          memory: 1G
        reservations:
          memory: 256M
    env_file:
      - .env
    environment:
      - LIVEKIT_URL=${LIVEKIT_INTERNAL_URL:-${LIVEKIT_URL:-}}
      - LIVEKIT_API_KEY=${LIVEKIT_API_KEY:-}
      - LIVEKIT_API_SECRET=${LIVEKIT_API_SECRET:-}
      - CHEERS_INTERNAL_URL=http://gateway:8000
      - VOICE_TRANSCRIBER_TOKEN=${VOICE_TRANSCRIBER_TOKEN:-}
      - VOICE_STT_API_KEY=${VOICE_STT_API_KEY:-}
      - VOICE_STT_PROVIDER=${VOICE_STT_PROVIDER:-openai}
      - VOICE_STT_BASE_URL=${VOICE_STT_BASE_URL:-}
      - VOICE_STT_MODEL=${VOICE_STT_MODEL:-gpt-4o-mini-transcribe}
      - VOICE_STT_LANGUAGE=${VOICE_STT_LANGUAGE:-}
    depends_on:
      gateway:
        condition: service_healthy

  # db-migrate 服务已移除：gateway 启动时自动跑 sqlx 迁移（main.rs: sqlx::migrate!）。

  frontend:
    env_file:
      - .env
    build:
      context: .
      dockerfile: frontend/Dockerfile
      args:
        VITE_API_PROXY_TARGET: ${VITE_API_PROXY_TARGET:-http://gateway:8000}
        VITE_WS_PROXY_TARGET: ${VITE_WS_PROXY_TARGET:-ws://gateway:8000}
        VITE_PUBLIC_BASE_PATH: ${VITE_PUBLIC_BASE_PATH:-/}
        VITE_API_BASE_URL: ${VITE_API_BASE_URL:-/api/v1}
        VITE_ENABLE_MERMAID: ${VITE_ENABLE_MERMAID:-1}
    restart: unless-stopped
    deploy:
      resources:
        limits:
          cpus: "0.5"
          memory: 128M
    ports:
      - "${FRONTEND_HOST_PORT:-80}:80"
    depends_on:
      - gateway

  # Office→PDF conversion for in-app document preview. Stateless; the gateway
  # feeds it bytes over the internal network (GOTENBERG_URL). LibreOffice inside
  # needs a little memory.
  gotenberg:
    image: ${GOTENBERG_IMAGE:-gotenberg/gotenberg:8}
    restart: unless-stopped
    # LibreOffice conversions are memory-hungry.
    deploy:
      resources:
        limits:
          cpus: "1"
          memory: 1G
        reservations:
          memory: 256M

  postgres:
    image: postgres:16-alpine
    restart: unless-stopped
    deploy:
      resources:
        limits:
          cpus: "2"
          memory: 1G
        reservations:
          memory: 256M
    ports:
      - "${POSTGRES_HOST_PORT:-5432}:5432"
    environment:
      - POSTGRES_USER=${POSTGRES_USER:-cheers}
      - POSTGRES_PASSWORD=${POSTGRES_PASSWORD:-cheers}
      - POSTGRES_DB=${POSTGRES_DB:-cheers}
    volumes:
      - ./data/postgres:/var/lib/postgresql/data
    healthcheck:
      test: ["CMD-SHELL", "pg_isready -U ${POSTGRES_USER:-cheers}"]
      interval: 5s
      timeout: 5s
      retries: 10

  redis:
    image: redis:7-alpine
    restart: unless-stopped
    deploy:
      resources:
        limits:
          cpus: "0.5"
          memory: 256M

  rustfs:
    image: rustfs/rustfs:latest
    restart: unless-stopped
    deploy:
      resources:
        limits:
          cpus: "1"
          memory: 1G
        reservations:
          memory: 256M
    security_opt:
      - "no-new-privileges:true"
    ports:
      - "${RUSTFS_API_HOST_PORT:-9000}:9000"
      - "${RUSTFS_CONSOLE_HOST_PORT:-9001}:9001"
    environment:
      - RUSTFS_VOLUMES=/data
      - RUSTFS_ADDRESS=0.0.0.0:9000
      - RUSTFS_CONSOLE_ADDRESS=0.0.0.0:9001
      - RUSTFS_CONSOLE_ENABLE=true
      - RUSTFS_CORS_ALLOWED_ORIGINS=${RUSTFS_CORS_ALLOWED_ORIGINS:-https://cheers.example.com}
      - RUSTFS_CONSOLE_CORS_ALLOWED_ORIGINS=${RUSTFS_CONSOLE_CORS_ALLOWED_ORIGINS:-https://cheers.example.com}
      - RUSTFS_ACCESS_KEY=${STORAGE_S3_ACCESS_KEY:-cheers-local-access-key}
      - RUSTFS_SECRET_KEY=${STORAGE_S3_SECRET_KEY:-cheers-local-secret-key}
      - RUSTFS_OBS_LOGGER_LEVEL=${RUSTFS_OBS_LOGGER_LEVEL:-info}
      - RUSTFS_OBJECT_CACHE_ENABLE=${RUSTFS_OBJECT_CACHE_ENABLE:-true}
      - RUSTFS_OBJECT_CACHE_TTL_SECS=${RUSTFS_OBJECT_CACHE_TTL_SECS:-300}
    volumes:
      - ./data/rustfs:/data
      - ./data/rustfs_logs:/logs
    healthcheck:
      test: ["CMD-SHELL", "wget -S -O /dev/null http://127.0.0.1:9000/rustfs/health/live 2>&1 | grep -Eq 'HTTP/[0-9.]+ (200|403)'"]
      interval: 5s
      timeout: 5s
      retries: 20
      start_period: 10s
